    </mxCell>

    <!-- ═══════════════════════════════════════ NOTES: INTERIM / STOP differences ═══════════════════════════════════════ -->

    <mxCell id="note_flows" value="&lt;b&gt;Other Handler Flows (same core path):&lt;/b&gt;&#xa;&#xa;• &lt;b&gt;INTERIM&lt;/b&gt;: InterimHandler.handleInterim() — identical steps 2–7; additionally calls SessionLifecycleManager.onSessionActivity() to refresh idle timeout in sorted-set expiry index.&#xa;• &lt;b&gt;STOP&lt;/b&gt;: StopHandler.stopProcessing() — steps 2–7 but removes session from list; calls onSessionTerminated() (removes from index + TTL key); no COA disconnect." style="text;html=1;strokeColor=#82b366;fillColor=#f9ffe0;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="10" y="1218" width="1000" height="70" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════ NOTES: HTTP API ═══════════════════════════════════════ -->

    <mxCell id="note_http" value="&lt;b&gt;HTTP API Flow (BucketResource):&lt;/b&gt;&#xa;&#xa;PATCH /cache/addBucket/{userName} → CacheClient.getUserData() → [add balance] → if new priority &gt; existing priority: COAService.clearAllSessionsAndSendCOA() → CacheClient.updateUserAndRelatedCaches()&#xa;Other endpoints: updateBucket (expiry), patchStatus, patchServiceStatus, deleteService — all follow the same: read cache → mutate → write cache pattern." style="text;html=1;strokeColor=#6c8ebf;fillColor=#f0f8ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="1020" y="1218" width="920" height="70" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
